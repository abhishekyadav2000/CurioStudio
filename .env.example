DATABASE_URL="file:./dev.db"

# GitHub API (optional — increases rate limits)
GITHUB_TOKEN=

# E2B Sandbox (https://e2b.dev) — real isolated execution
E2B_API_KEY=

# ── Hybrid LLM Strategy ──────────────────────────────────────
# Per-task providers (auto | ollama | openai | claude | template)
# Auto = best premium if keys exist → Ollama → template
SCRIPT_PROVIDER=auto
SLIDE_PROVIDER=auto
REFINE_PROVIDER=auto
THUMBNAIL_PROVIDER=auto

# Ollama (local, free, private)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3
OLLAMA_VISION_MODEL=llava

# OpenAI (ChatGPT subscription / API)
OPENAI_API_KEY=
OPENAI_SCRIPT_MODEL=gpt-4o
OPENAI_QUICK_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude subscription / API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Legacy global override (optional)
LLM_PROVIDER=auto

# YouTube Data API OAuth (optional — manual copy-paste works without this)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Scanner paths (optional)
TRIVY_PATH=trivy
OSV_SCANNER_PATH=osv-scanner

# Kaggle API (optional — authenticated access for datasets/notebooks)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Hugging Face (optional — higher rate limits for private spaces)
HF_TOKEN=

# Dev server port (default 3000)
PORT=3000
